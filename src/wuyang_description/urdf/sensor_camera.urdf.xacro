<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sensor_camera">
    <xacro:macro name="GeminiPro_camera" params="parent xyz">
        <!-- Camera body: black rectangular prism 11.5cm x 1.7cm x 2.2cm -->
        <link name="camera_body_link">
            <inertial>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <mass value="0.05"/>
                <inertia ixx="0.000057" ixy="0.0" ixz="0.0" iyy="0.000003" iyz="0.0" izz="0.000056"/>
            </inertial>
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <box size="0.017 0.115 0.022"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <box size="0.017 0.115 0.022"/>
                </geometry>
            </collision>
        </link>

        <!-- Camera pitch link -->
        <link name="camera_pitch_link">
            <inertial>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <mass value="0.1"/>
                <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
            </inertial>
        </link>

        <!-- Revolute joint: parent → camera_pitch_link, rotates around Y axis 0~45 degrees (forward pitch) -->
        <joint name="camera_base_joint" type="revolute">
            <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
            <parent link="${parent}"/>
            <child link="camera_pitch_link"/>
            <axis xyz="0.0 1.0 0.0"/>
            <limit lower="0.0" upper="0.7854" effort="1.0" velocity="1.0"/>
        </joint>

        <!-- Fixed joint: camera_pitch_link → camera_body_link -->
        <joint name="camera_mount_joint" type="fixed">
            <origin xyz="-0.0085 0.0 0.011" rpy="0.0 0.0 0.0"/>
            <parent link="camera_pitch_link"/>
            <child link="camera_body_link"/>
            <axis xyz="0.0 0.0 0.0"/>
        </joint>

        
        <gazebo reference="camera_body_link">
            <sensor type="depth" name="camera_sensor">
                <plugin name="depth_camera" filename="libgazebo_ros_camera.so">
                    <frame_name>camera_optical_link</frame_name>
                </plugin>
                <always_on>true</always_on>
                <update_rate>10</update_rate>
                <camera name="camera">
                    <horizontal_fov>1.5009831567</horizontal_fov>
                </camera>
                <image>
                    <width>800</width>
                    <height>600</height>
                    <format>R8G8B8</format>
                </image>
                <distortion>
                    <k1>0.0</k1>
                    <k2>0.0</k2>
                    <k3>0.0</k3>
                    <p1>0.0</p1>
                    <p2>0.0</p2>
                    <center>0.5 0.5</center>
                </distortion>
            </sensor>
        </gazebo>

    </xacro:macro>
</robot>
