<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sensor_camera">
    <xacro:macro name="GeminiPro_camera" params="parent xyz">
        <link name="camera_body_link">
            <inertial>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <mass value="0.05"/>
                <inertia ixx="0.000057" ixy="0.0" ixz="0.0" iyy="0.000003" iyz="0.0" izz="0.000056"/>
            </inertial>
            <visual>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <box size="0.017 0.115 0.022"/>
                </geometry>
                <material name="black"/>
            </visual>
            <collision>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <geometry>
                    <box size="0.017 0.115 0.022"/>
                </geometry>
            </collision>
        </link>

        <link name="camera_pitch_link">
            <inertial>
                <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
                <mass value="0.1"/>
                <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
            </inertial>
        </link>

        <joint name="camera_base_joint" type="revolute">
            <origin xyz="${xyz}" rpy="0.0 0.0 0.0"/>
            <parent link="${parent}"/>
            <child link="camera_pitch_link"/>
            <axis xyz="0.0 1.0 0.0"/>
            <limit lower="0.0" upper="0.7854" effort="1.0" velocity="1.0"/>
        </joint>

        <joint name="camera_mount_joint" type="fixed">
            <origin xyz="-0.0085 0.0 0.011" rpy="0.0 0.0 0.0"/>
            <parent link="camera_pitch_link"/>
            <child link="camera_body_link"/>
            <axis xyz="0.0 0.0 0.0"/>
        </joint>

        <link name="camera_optical_link"/>
        <joint name="camera_optical_joint" type="fixed">
            <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
            <parent link="camera_body_link"/>
            <child link="camera_optical_link"/>
        </joint>

        <gazebo reference="camera_body_link">
            <sensor type="depth" name="gemini_pro_sensor">
                <always_on>true</always_on>
                <update_rate>30.0</update_rate>
                <camera>
                    <horizontal_fov>1.5708</horizontal_fov>
                    <image>
                        <width>800</width>
                        <height>600</height>
                        <format>R8G8B8</format>
                    </image>
                    <clip>
                        <near>0.15</near>
                        <far>10.0</far>
                    </clip>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.007</stddev>
                    </noise>
                </camera>
                <plugin name="gemini_camera_controller" filename="libgazebo_ros_camera.so">
                    <ros>
                        <namespace>/</namespace>
                        <remapping>~/image_raw:=image_raw</remapping>
                        <remapping>~/camera_info:=camera_info</remapping>
                        <remapping>~/depth/image_raw:=depth/image_raw</remapping>
                        <remapping>~/depth/camera_info:=depth/camera_info</remapping>
                        <remapping>~/points:=points</remapping>
                    </ros>
                    <camera_name>gemini_pro</camera_name>
                    <frame_name>camera_optical_link</frame_name>
                    <min_depth>0.15</min_depth>
                    <max_depth>10.0</max_depth>
                </plugin>
            </sensor>
        </gazebo>

    </xacro:macro>
</robot>
